# ══════════════════════════════════════════════════════════════════════════════
# Petoria — Production Environment Template
#
# Instructions:
#   1. Copy this file:  cp .env.production.example .env.production
#   2. Fill in every CHANGE_ME value
#   3. Verify .env.production is in .gitignore before committing anything
#   4. Never commit .env.production to version control
# ══════════════════════════════════════════════════════════════════════════════

# ── Runtime ───────────────────────────────────────────────────────────────────
# Must be "production". Controls:
#   • MongoDB URI selection (MONGO_PROD used when production)
#   • GraphQL Playground (disabled when production)
#   • CORS origin validation (throws at startup if CORS_ORIGINS is missing)
NODE_ENV=production

# ── Ports ─────────────────────────────────────────────────────────────────────
# Internal container ports. Exposed on 127.0.0.1 only via docker-compose.
# End users never reach these directly — all traffic goes through Nginx.
PORT_API=3002
PORT_BATCH=3003

# ── Database ──────────────────────────────────────────────────────────────────
# MONGO_PROD: production Atlas cluster. Use a DEDICATED database — not the
# same one used for development. Restrict Atlas Network Access to the VPS IP.
#
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_PROD=mongodb+srv://CHANGE_ME_USER:CHANGE_ME_PASSWORD@cluster0.CHANGE_ME.mongodb.net/Petoria?retryWrites=true&w=majority

# MONGO_DEV is never read when NODE_ENV=production.
# Set to this sentinel value to make accidental use obvious in logs.
MONGO_DEV=NOT_USED_IN_PRODUCTION

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Used to sign all JWT access tokens. If this value leaks, every user account
# is compromised — an attacker can forge tokens for any member including admins.
#
# Requirements:
#   • Must be cryptographically random
#   • Minimum 32 characters (48+ recommended)
#   • Must differ from the development SECRET_TOKEN
#
# Generate a secure value:
#   openssl rand -base64 48
#
# Example output (do not use this exact value):
#   5K9mN2pQrT8vXz3bLjY7hWnA1dEuCsGfIoMkR4wV6yZ==
SECRET_TOKEN=CHANGE_ME_openssl_rand_-base64_48

# ── CORS ──────────────────────────────────────────────────────────────────────
# The frontend origin that is allowed to make cross-origin GraphQL requests.
# The application throws at startup if this variable is missing in production.
#
# Single domain:
#   CORS_ORIGINS=https://petoria.example.com
#
# Multiple domains (comma-separated, no spaces):
#   CORS_ORIGINS=https://petoria.example.com,https://www.petoria.example.com
CORS_ORIGINS=https://CHANGE_ME.com
