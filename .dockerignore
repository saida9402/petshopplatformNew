# ── Dependencies ──────────────────────────────────────────────────────────────
# Always rebuilt inside the container via npm ci.
node_modules

# ── Build output ──────────────────────────────────────────────────────────────
# Built inside the builder stage; local dist is stale and must not leak in.
dist

# ── Environment files ─────────────────────────────────────────────────────────
# Secrets are injected at runtime via docker-compose env_file.
# No .env file of any kind should be baked into the image.
.env
.env.*

# ── Uploads ───────────────────────────────────────────────────────────────────
# User-uploaded files are managed by a named Docker volume, not the image.
uploads

# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Test and coverage ─────────────────────────────────────────────────────────
coverage
.nyc_output
**/*.spec.ts
**/*.e2e-spec.ts
**/test/

# ── Editor and OS artifacts ───────────────────────────────────────────────────
.vscode
.idea
*.sublime-workspace
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
logs
*.log

# ── Seed / utility scripts ────────────────────────────────────────────────────
seed*.js
download-images.js
train.ts

# ── Source maps ───────────────────────────────────────────────────────────────
# Generated by webpack in the builder; excluded from the production image.
**/*.js.map

# ── Nginx config ──────────────────────────────────────────────────────────────
# Only needed on the host — Nginx runs in its own container.
nginx/

# ── CI / docs ─────────────────────────────────────────────────────────────────
*.md
.github/
